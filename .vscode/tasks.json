{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "Client compile",
         "type": "npm",
         "script": "client-compile",
         "group": "build",
         "presentation": {
            "panel": "dedicated",
            "reveal": "never",
         },
         "problemMatcher": ["$tsc"],
      },
      {
         "label": "Client watch",
         "type": "npm",
         "script": "watch",
         "isBackground": true,
         "group": {
            "kind": "build",
            "isDefault": true,
         },
         "presentation": {
            "focus": true,
            "panel": "dedicated",
            "reveal": "never",
            "group": "build",
         },
         "problemMatcher": ["$tsc-watch"],
      },
   ],
}
